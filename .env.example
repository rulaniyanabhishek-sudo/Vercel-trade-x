# Trade X server configuration
PORT=8080

# Use official Upstox server-side adapter
MARKET_DATA_PROVIDER=upstox
UPSTOX_ACCESS_TOKEN=paste_your_upstox_access_token_here

# Optional: pin NIFTY expiry. If omitted, server picks nearest NIFTY expiry from Upstox instrument master.
# Format: YYYY-MM-DD
# UPSTOX_NIFTY_EXPIRY_DATE=2026-07-14

# Refresh/caching intervals
BQ_LIVE_TTL_MS=1000
BQ_CLOSED_TTL_MS=30000
BQ_OPTIONS_TTL_MS=1000
BQ_OPTIONS_CLOSED_TTL_MS=15000
BQ_FETCH_CONCURRENCY=6

# Optional CORS restriction. Use * while testing, your GitHub Pages URL in production.
BQ_CORS_ORIGIN=*
